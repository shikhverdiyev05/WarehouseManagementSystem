@model IEnumerable<WarehouseMS.Models.Stock>

@{
    ViewData["Title"] = "Mövcud Stok";
}

<div class="card shadow-sm border-0" style="border-radius: 15px;">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="m-0 fw-bold text-secondary">
                <i class="fas fa-layer-group me-2 text-primary"></i>Mövcud Stok Vəziyyəti
            </h4>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle" id="stockTable">
                <thead class="bg-light">
                    <tr>
                        <th>Məhsul Adı</th>
                        <th>Anbar</th>
                        <th>Rəf</th>
                        <th>Miqdar</th>
                        <th>Status</th>
                        <th>Vəziyyət</th>
                        <th class="text-center">Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Product?.Name</td>
                            <td>@item.Warehouse?.Name</td>
                            <td><span class="badge bg-info text-dark">@item.Shelf?.ShelfCode</span></td>
                            <td class="fw-bold text-primary">@item.Quantity @item.Product?.Unit</td>
                            <td>
                                @if (item.Quantity <= (item.Product?.MinStockLevel ?? 0))
                                {
                                    <span class="badge bg-danger"><i class="fas fa-exclamation-triangle"></i> Kritik</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Normal</span>
                                }
                            </td>
                            <td>
                                @if (item.Type == "In")
                                {
                                    <span class="badge bg-success-subtle text-success px-2 py-1">
                                        <i class="fas fa-arrow-down me-1"></i> Giriş
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-subtle text-danger px-2 py-1">
                                        <i class="fas fa-arrow-up me-1"></i> Çıxış
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-edit"></i> Düzəliş
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#stockTable').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.4/i18n/az-AZ.json'
                }
            });
        });
    </script>
}