@model WarehouseMS.Models.Product

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@Model.Name - <span class="text-muted small">@Model.SKU</span></h2>
        <a asp-controller="Stock" asp-action="Create" asp-route-productId="@Model.Id" class="btn btn-success">
            <i class="fas fa-plus"></i> Stoka Məhsul Artır
        </a>
    </div>

    <div class="row">
        <div class="col-md-4">
            <p><strong>Kateqoriya:</strong> @Model.Category?.Name</p>
            <p><strong>Qiymət:</strong> @Model.SalePrice ₼</p>
            <p><strong>Vahid:</strong> @Model.Unit</p>
        </div>

        <div class="col-md-8">
            <h5>Mövcud Stoklar</h5>
            <table class="table border">
                <thead class="bg-light">
                    <tr>
                        <th>Anbar</th>
                        <th>Rəf</th>
                        <th>Miqdar</th>
                        <th>Əməliyyat</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stock in Model.Stocks)
                    {
                        <tr>
                            <td>@stock.Warehouse?.Name</td>
                            <td>@(stock.Shelf?.ShelfCode ?? "Rəf təyin edilməyib")</td>
                            <td class="fw-bold">@stock.Quantity @Model.Unit</td>
                            <td>
                                <a asp-controller="Stock" asp-action="Edit" asp-route-id="@stock.Id" class="btn btn-sm btn-outline-warning">Sayı Düzəlt</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>