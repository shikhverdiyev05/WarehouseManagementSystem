@model WarehouseMS.Models.Product

<div class="glass-card p-4 mx-auto" style="max-width: 800px;">
    <h3 class="text-warning mb-4"><i class="fas fa-edit me-2"></i>Məhsulu Redaktə Et</h3>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="SKU" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="fw-bold">Məhsulun Adı</label>
                <input asp-for="Name" class="form-control" required />
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Kateqoriya</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId">
                    <option value="">-- Kateqoriya Seçin --</option>
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Maya Dəyəri</label>
                <input asp-for="CostPrice" type="number" step="0.01" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <label class="fw-bold">Satış Qiyməti</label>
                <input asp-for="SalePrice" type="number" step="0.01" class="form-control" />
            </div>

            <div class="col-md-6 mb-3">
                <input type="hidden" asp-for="Barcode" />
                <div class="mb-2">
                    <label class="form-label fw-bold text-secondary">Məhsul Barkodu (Dəyişdirilə bilməz)</label>
                    <input type="text" class="form-control bg-light text-muted" value="@Model.Barcode" readonly />
                </div>
            </div>
            
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-warning px-4 fw-bold text-white">Yadda Saxla</button>
            <a asp-action="Index" class="btn btn-light px-4">Ləğv Et</a>
        </div>
    </form>
</div>