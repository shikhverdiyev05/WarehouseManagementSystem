@model IEnumerable<WarehouseMS.Models.StockMovement>

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="fas fa-history text-secondary me-2"></i>Stok Hərəkət Tarixçəsi</h3>
        <a asp-action="Create" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> Yeni Əməliyyat</a>
    </div>

    <table class="table table-hover" id="moveTable">
        <thead class="table-light">
            <tr>
                <th>Tarix</th>
                <th>Məhsul</th>
                <th>Tip</th>
                <th>Miqdar</th>
                <th>Qeyd</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="fw-bold">@item.Product?.Name</td>
                    <td>
                        @if (item.Type == "In")
                        {
                            <span class="badge bg-success-subtle text-success border border-success"><i class="fas fa-arrow-down"></i> Giriş</span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger border border-danger"><i class="fas fa-arrow-up"></i> Çıxış</span>
                        }
                    </td>
                    <td class="fw-bold">@item.Quantity</td>
                    <td class="text-muted small">@item.Note</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#moveTable').DataTable({
                order: [[0, 'desc']]
            });
        });
    </script>
}