<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WarehouseMS</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --sidebar-width: 260px;
            --primary-color: #6366f1;
            --glass-bg: rgba(255, 255, 255, 0.8);
        }

        body {
            background: #f3f4f6;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        /* Sidebar Stili */
        #sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            background: #1e293b;
            color: white;
            transition: all 0.3s;
            z-index: 1000;
        }

        #sidebar .nav-link {
            color: #94a3b8;
            padding: 12px 20px;
            margin: 4px 10px;
            border-radius: 8px;
        }

        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            background: var(--primary-color);
            color: white;
        }

        #sidebar .nav-link i {
            width: 25px;
        }

        /* Əsas Kontent */
        #content {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            padding: 20px;
            transition: all 0.3s;
        }

        /* Top Navbar */
        .top-nav {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.05);
            padding: 15px 30px;
            margin-bottom: 30px;
            border-radius: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
    </style>
</head>
<body>

    <nav id="sidebar">
        <div class="p-4 text-center">
            <h4 class="fw-bold"><i class="fas fa-warehouse me-2 text-primary"></i>WMS PRO</h4>
        </div>
        <div class="nav flex-column mt-3">
            <a class="nav-link active" asp-controller="Dashboard" asp-action="Index">
                <i class="fas fa-chart-line"></i> Dashboard
            </a>
            <hr class="mx-3 opacity-25">
            <div class="px-4 mb-2 small text-uppercase opacity-50">Anbar</div>
            <a class="nav-link" asp-controller="Product" asp-action="Index">
                <i class="fas fa-boxes"></i> Məhsullar
            </a>
            <a class="nav-link" asp-controller="Category" asp-action="Index">
                <i class="fas fa-tags"></i> Kateqoriyalar
            </a>
            <a class="nav-link" asp-controller="Warehouse" asp-action="Index">
                <i class="fas fa-map-marker-alt"></i> Anbarlar & Rəflər
            </a>
            <a class="nav-link" asp-controller="Stock" asp-action="Index">
                <i class="fas fa-layer-group"></i> Mövcud Stok
            </a>
            <a class="nav-link" asp-controller="Stock" asp-action="Movements">
                <i class="fas fa-history"></i> Stok Hərəkətləri
            </a>
            <hr class="mx-3 opacity-25">
            <div class="px-4 mb-2 small text-uppercase opacity-50">Ticarət</div>
            <a class="nav-link" asp-controller="Sale" asp-action="Index">
                <i class="fas fa-shopping-cart"></i> Satışlar
            </a>
            <a class="nav-link" asp-controller="Supplier" asp-action="Index">
                <i class="fas fa-truck"></i> Tədarükçülər
            </a>
            <a class="nav-link" asp-controller="AuditLog" asp-action="Index">
                <i class="fas fa-shopping-cart"></i> AuditLog
            </a>

            <hr class="mx-3 opacity-25">
            <a class="nav-link text-danger mt-5" asp-controller="Account" asp-action="Logout">
                <i class="fas fa-sign-out-alt"></i> Çıxış
            </a>
        </div>
    </nav>

    <main id="content">
        <header class="top-nav">
            <div>
                <h5 class="m-0 fw-bold text-secondary">Xoş gəlmisiniz!</h5>
            </div>
            <div class="d-flex align-items-center">
                <div class="me-3 text-end">
                    <div class="fw-bold">@Context.Session.GetString("UserFullName")</div>
                    <small class="text-muted">Administrator</small>
                </div>
                <img src="https://ui-avatars.com/api/?name=@Context.Session.GetString("UserFullName")&background=6366f1&color=fff" class="rounded-circle" width="40" height="40">
            </div>
        </header>

        <div class="container-fluid">
            @RenderBody()
        </div>
    </main>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.4/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>