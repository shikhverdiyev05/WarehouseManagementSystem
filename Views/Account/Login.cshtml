@using WarehouseMS.ViewModels
@model LoginVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>WarehouseMS | Giriş</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/auth.css">
</head>
<body class="auth-bg">
    <div class="login-box glass-effect">
        <h2 class="text-center mb-4">Sistemə Giriş</h2>
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

            <div class="mb-3">
                <label>E-poçt</label>
                <input asp-for="Email" class="form-control bg-transparent text-white" placeholder="email@example.com">
            </div>

            <div class="mb-3">
                <label>Şifrə</label>
                <input asp-for="Password" type="password" class="form-control bg-transparent text-white" placeholder="******">
            </div>

            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input">
                <label class="form-check-label">Məni xatırla</label>
            </div>

            <button type="submit" class="btn btn-primary w-100 mb-3">Daxil ol</button>
            <p class="text-center small">Hesabınız yokdur? <a asp-action="Register" class="text-info">Qeydiyyatdan keçin</a></p>
        </form>
    </div>
</body>
</html>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 1. Səhifə açılanda yoxla: Əgər istifadəçi artıq login olubsa, birbaşa ana səhifəyə göndər
            const savedUser = localStorage.getItem("userFullName");
            if (savedUser) {
                window.location.href = "/Sale/Index"; // Uğurlu girişdən sonra hara getsin?
            }
        });

        // 2. Login düyməsinə basılanda işləyən funksiya (Form POST olub uğurlu cavab dönəndə)
        function handleLoginSuccess(userFullName) {
            // İstifadəçinin adını brauzerin yaddaşına daimi yazırıq
            localStorage.setItem("userFullName", userFullName);
            window.location.href = "/Sale/Index";
        }

        // 3. Proqramdan Çıxış (Logout) düyməsi üçün funksiya (Bunu Navbar-dakı Çıxış düyməsinə verərsən)
        function logoutUser() {
            localStorage.removeItem("userFullName"); // Yaddaşı təmizləyirik
            window.location.href = "/Account/Login";
        }
    </script>
}