@using WarehouseMS.ViewModels
@model RegisterVM
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="az">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WarehouseMS | Qeydiyyat</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/auth.css">
</head>
<body class="auth-bg">
    <div class="login-box glass-effect">
        <div class="text-center mb-4">
            <i class="fas fa-user-plus fa-3x text-info"></i>
            <h2 class="mt-2">Yeni Hesab</h2>
            <p class="text-white-50">Sistemə qoşulmaq üçün formu doldurun</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Ad və Soyad</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent text-white-50 border-end-0"><i class="fas fa-user"></i></span>
                    <input asp-for="FullName" class="form-control bg-transparent text-white border-start-0" placeholder="Məs: Əli Əliyev">
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">E-poçt</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent text-white-50 border-end-0"><i class="fas fa-envelope"></i></span>
                    <input asp-for="Email" type="email" class="form-control bg-transparent text-white border-start-0" placeholder="email@example.com">
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Şifrə</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent text-white-50 border-end-0"><i class="fas fa-lock"></i></span>
                    <input asp-for="Password" type="password" class="form-control bg-transparent text-white border-start-0" placeholder="******">
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Şifrənin Təkrarı</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent text-white-50 border-end-0"><i class="fas fa-check-double"></i></span>
                    <input asp-for="ConfirmPassword" type="password" class="form-control bg-transparent text-white border-start-0" placeholder="******">
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-info w-100 mb-3 text-white fw-bold">Qeydiyyatı Tamamla</button>

            <div class="text-center">
                <p class="small mb-0">Artıq hesabınız var? <a asp-action="Login" class="text-info fw-bold decoration-none">Daxil olun</a></p>
            </div>
        </form>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>