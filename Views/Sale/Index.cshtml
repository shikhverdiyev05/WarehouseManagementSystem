@model IEnumerable<WarehouseMS.Models.Sale>

@{
    ViewData["Title"] = "Satışlar";
}

<div class="card shadow-sm border-0" style="border-radius: 15px;">
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="m-0 fw-bold text-secondary">
                <i class="fas fa-shopping-cart me-2 text-primary"></i>Satış Siyahısı
            </h4>
            <a asp-action="Create" class="btn btn-primary btn-sm px-3" style="border-radius: 8px; background: var(--primary-color);">
                <i class="fas fa-plus me-1"></i> Yeni Satış Et
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped align-middle" id="salesTable">
                <thead class="bg-light">
                    <tr>
                        <th>Tarix</th>
                        <th>Məhsul</th>
                        <th>Anbar</th>
                        <th>Miqdar</th>
                        <th>Məbləğ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">@item.Date.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-bold">@item.Product?.Name</td>
                            <td>@item.Warehouse?.Name</td>
                            <td>@item.Quantity</td>
                            <td class="fw-bold text-success">@(item.Quantity* item.Price) AZN</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#salesTable').DataTable({
                "order": [[0, "desc"]],
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.4/i18n/az-AZ.json"
                }
            });
        });
    </script>
}