@model WarehouseMS.Models.Supplier

@{
    ViewData["Title"] = "Yeni Tədarükçü";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm border-0" style="border-radius: 15px;">
            <div class="card-body p-4">
                <h4 class="mb-4 fw-bold text-secondary">
                    <i class="fas fa-user-plus me-2 text-primary"></i>Yeni Tədarükçü Kartı
                </h4>
                <hr class="opacity-25 mb-4">

                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CompanyName" class="form-label fw-bold text-secondary">Şirkətin Adı</label>
                        <input asp-for="CompanyName" class="form-control" placeholder="Məs: Sumgait Logistics MMC" required />
                        <span asp-validation-for="CompanyName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ContactName" class="form-label fw-bold text-secondary">Əlaqədar Şəxs (Ad, Soyad)</label>
                        <input asp-for="ContactName" class="form-control" placeholder="Məs: Əli Məmmədov" required />
                        <span asp-validation-for="ContactName" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="Phone" class="form-label fw-bold text-secondary">Telefon</label>
                            <input asp-for="Phone" class="form-control" placeholder="+994 (XX) XXX-XX-XX" required />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="Email" class="form-label fw-bold text-secondary">E-poçt ünvanı</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="info@company.az" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Address" class="form-label fw-bold text-secondary">Faktiki Ünvan</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Bakı şəhəri, Nərimanov r..." required></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Index" class="btn btn-light px-4" style="border-radius: 8px;">Geri</a>
                        <button type="submit" class="btn btn-primary px-4" style="border-radius: 8px; background: var(--primary-color);">
                            <i class="fas fa-save me-1"></i> Yadda Saxla
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}