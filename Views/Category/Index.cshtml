@model IEnumerable<WarehouseMS.Models.Category>

<div class="glass-card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="fas fa-tags text-primary me-2"></i>Kateqoriyalar</h3>
        <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Yeni Kateqoriya</a>
    </div>

    <table class="table table-hover" id="categoryTable">
        <thead class="table-light">
            <tr>
                <th>Adı</th>
                <th>Təsvir</th>
                <th class="text-end">Əməliyyatlar</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="row-@item.Id">
                    <td class="fw-bold">@item.Name</td>
                    <td class="text-muted small">@item.Description</td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                            <i class="fas fa-edit"></i>
                        </a>
                        <button onclick="deleteCat(@item.Id)" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            $('#categoryTable').DataTable();
        });

        function deleteCat(id) {
            Swal.fire({
                title: 'Əminsiniz?',
                text: "Bu kateqoriya silinəcək!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Bəli, sil!',
                cancelButtonText: 'Ləğv et'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post("/Category/Delete/" + id, function (res) {
                        if (res.success) {
                            $("#row-" + id).fadeOut(500);
                            Swal.fire('Silindi!', 'Kateqoriya uğurla silindi.', 'success');
                        } else {
                            Swal.fire('Xəta!', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}