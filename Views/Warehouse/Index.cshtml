@model IEnumerable<WarehouseMS.Models.Warehouse>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="fas fa-warehouse text-primary me-2"></i>Anbarların İdarə Edilməsi</h3>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="fas fa-plus me-1"></i> Yeni Anbar
        </a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4" id="card-@item.Id">
                <div class="card h-100 shadow-sm border-0 glass-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h5 class="card-title fw-bold text-dark">@item.Name</h5>
                                <p class="text-muted small"><i class="fas fa-map-marker-alt me-1"></i> @item.Location</p>
                            </div>
                            <span class="badge bg-soft-info text-info rounded-pill p-2">
                                @(item.Shelves?.Count ?? 0) Rəf
                            </span>
                        </div>

                        <hr class="my-3">

                        <div class="d-flex gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="fas fa-th me-1"></i> Rəflər
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <button onclick="confirmDelete(@item.Id, '@item.Name')" class="btn btn-sm btn-outline-danger">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Əminsiniz?',
                text: name + " adlı anbar silinəcək. Bu əməliyyat geri qaytarıla bilməz!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Bəli, sil!',
                cancelButtonText: 'Ləğv et'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '/Warehouse/Delete/' + id,
                        type: 'POST',
                        success: function (response) {
                            if (response.success) {
                                Swal.fire('Silindi!', 'Anbar uğurla silindi.', 'success');
                                $("#card-" + id).fadeOut(500); // Kartı səhifədən itir
                            } else {
                                Swal.fire('Xəta!', response.message, 'error');
                            }
                        },
                        error: function () {
                            Swal.fire('Xəta!', 'Serverlə əlaqə zamanı problem yarandı.', 'error');
                        }
                    });
                }
            })
        }
    </script>
}