@model WarehouseMS.Models.Warehouse

<div class="glass-card p-4 mx-auto" style="max-width: 600px;">
    <h3 class="text-warning mb-4"><i class="fas fa-edit me-2"></i>Anbarı Redaktə Et</h3>
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <label class="fw-bold">Anbar Adı</label>
            <input asp-for="Name" class="form-control" required />
        </div>
        <div class="mb-3">
            <label class="fw-bold">Ünvan / Yerləşmə</label>
            <input asp-for="Location" class="form-control" required />
        </div>
        <div class="mt-4">
            <button type="submit" class="btn btn-warning text-white px-4 fw-bold">Yadda Saxla</button>
            <a asp-action="Index" class="btn btn-light">Ləğv Et</a>
        </div>
    </form>
</div>